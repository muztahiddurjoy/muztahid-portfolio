# --- Required ---
# MongoDB connection string (use MongoDB Atlas in production)
DATABASE_URL=mongodb://127.0.0.1/your-database-name
# Long random string used to sign auth tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# --- Production (recommended) ---
# Durable media storage on serverless hosts (the filesystem is ephemeral).
# When all three are set, uploads are offloaded to Cloudinary and served via its
# CDN; when unset, local disk is used (dev only). Find these in your Cloudinary
# dashboard (Settings → API Keys).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional. Cloudinary folder to store uploads under (default: muztahid-portfolio).
CLOUDINARY_FOLDER=
# Absolute site URL — drives canonical metadata, sitemap and robots, and is the
# postMessage origin for Live Preview. Set to your dev origin locally
# (e.g. http://localhost:3000) and the deployed URL in production.
NEXT_PUBLIC_SITE_URL=https://muztahid.dev
# Long random string gating the draft-mode preview route used by Live Preview.
PREVIEW_SECRET=YOUR_PREVIEW_SECRET
