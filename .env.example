# --- Required ---
# MongoDB connection string (use MongoDB Atlas in production)
DATABASE_URL=mongodb://127.0.0.1/your-database-name
# Long random string used to sign auth tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# --- Production (recommended) ---
# Durable media storage on serverless hosts (Vercel's filesystem is ephemeral).
# When set, uploads go to Vercel Blob; when unset, local disk is used (dev only).
BLOB_READ_WRITE_TOKEN=
# Absolute site URL — drives canonical metadata, sitemap and robots.
NEXT_PUBLIC_SITE_URL=https://muztahid.dev
